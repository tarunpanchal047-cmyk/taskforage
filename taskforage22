<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TaskForge — AI Task Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07080c;--bg2:#0d0f17;--bg3:#13161f;--bg4:#1a1d28;
  --border:#252836;--border2:#2f3347;
  --text:#ecedf5;--text2:#8b8fa8;--text3:#555870;
  --accent:#00e5c0;--accent2:#00c4a4;
  --accent-dim:rgba(0,229,192,0.08);--accent-glow:rgba(0,229,192,0.2);
  --warn:#f5a623;--err:#ff4d6a;--info:#4d9fff;
  --success:#00e5c0;--pending-c:#a78bfa;--running-c:#38bdf8;
  --font-head:'Syne',sans-serif;--font-mono:'IBM Plex Mono',monospace;
  --r:6px;--r2:10px;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font-mono);font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}
button{font-family:var(--font-mono);cursor:pointer;border:none;transition:all .15s}
button:disabled{opacity:.4;cursor:not-allowed}
input,textarea,select{font-family:var(--font-mono);font-size:13px;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);color:var(--text);padding:9px 12px;width:100%;outline:none;transition:border-color .15s}
input:focus,textarea:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim)}
input::placeholder,textarea::placeholder{color:var(--text3)}
select option{background:var(--bg3)}
label{display:block;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);margin-bottom:5px}

.page{display:none;min-height:100vh}
.page.active{display:flex}

/* AUTH */
#page-auth{align-items:center;justify-content:center;background:var(--bg);position:relative;overflow:hidden}
#page-auth::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% -5%,rgba(0,229,192,.07) 0%,transparent 65%);pointer-events:none}
#page-auth::after{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:40px 40px;opacity:.25;pointer-events:none}
.auth-wrap{width:100%;max-width:420px;padding:20px;position:relative;z-index:1}
.auth-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:40px}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:32px;justify-content:center}
.auth-logo-mark{width:36px;height:36px;border:2px solid var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.auth-logo-name{font-family:var(--font-head);font-size:22px;font-weight:800;letter-spacing:-.02em;color:var(--text)}
.auth-tabs{display:flex;background:var(--bg3);border-radius:var(--r);padding:3px;margin-bottom:28px}
.auth-tab{flex:1;padding:7px;text-align:center;border-radius:5px;font-size:12px;font-weight:600;cursor:pointer;color:var(--text2);background:transparent;border:none;transition:all .15s;text-transform:uppercase;letter-spacing:.06em}
.auth-tab.active{background:var(--bg4);color:var(--text);border:1px solid var(--border)}
.field{margin-bottom:16px}
.btn-primary{width:100%;background:var(--accent);color:#000;font-weight:700;font-size:13px;padding:11px;border-radius:var(--r);letter-spacing:.04em;text-transform:uppercase;margin-top:8px;cursor:pointer;border:none}
.btn-primary:hover:not(:disabled){background:var(--accent2)}
.err-box{background:rgba(255,77,106,.1);border:1px solid rgba(255,77,106,.3);color:var(--err);padding:9px 12px;border-radius:var(--r);font-size:12px;margin-bottom:14px}
.auth-form-panel{display:none}
.auth-form-panel.active{display:block}
.demo-hint{text-align:center;margin-top:14px;font-size:11px;color:var(--text3)}

/* APP */
#page-app{flex-direction:column}
.navbar{height:56px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 24px;gap:16px;position:sticky;top:0;z-index:100}
.nav-logo{display:flex;align-items:center;gap:8px;margin-right:auto}
.nav-logo-mark{width:28px;height:28px;border:1.5px solid var(--accent);border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-logo-name{font-family:var(--font-head);font-weight:800;font-size:16px;letter-spacing:-.02em}
.nav-user{font-size:12px;color:var(--text2);display:flex;align-items:center;gap:6px}
.nav-dot{width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);flex-shrink:0}
.btn-signout{background:transparent;border:1px solid var(--border2);color:var(--text2);padding:5px 12px;border-radius:var(--r);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap}
.btn-signout:hover{border-color:var(--err);color:var(--err)}
.app-body{flex:1;max-width:1100px;margin:0 auto;width:100%;padding:32px 24px}

.view{display:none}
.view.active{display:block}

/* DASHBOARD */
.dash-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:28px;gap:16px;flex-wrap:wrap}
.dash-title{font-family:var(--font-head);font-size:28px;font-weight:800;letter-spacing:-.03em;line-height:1.1}
.dash-sub{font-size:12px;color:var(--text2);margin-top:5px}
.btn-new-task{background:var(--accent);color:#000;font-weight:700;font-size:12px;padding:9px 18px;border-radius:var(--r);text-transform:uppercase;letter-spacing:.06em;display:flex;align-items:center;gap:6px;white-space:nowrap;cursor:pointer;border:none}
.btn-new-task:hover{background:var(--accent2)}

/* Stats */
.stats-row{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:28px}
.stat{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:16px 14px}
.stat-n{font-family:var(--font-head);font-size:26px;font-weight:800;line-height:1;color:var(--text)}
.stat-l{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);margin-top:5px}
.stat-pending .stat-n{color:var(--pending-c)}
.stat-running .stat-n{color:var(--running-c)}
.stat-success .stat-n{color:var(--success)}
.stat-failed .stat-n{color:var(--err)}

/* Create panel */
.create-panel{background:var(--bg2);border:1px solid var(--accent);border-radius:var(--r2);padding:24px;margin-bottom:24px;display:none}
.create-panel.open{display:block;animation:slideDown .2s ease}
@keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.create-title{font-family:var(--font-head);font-size:15px;font-weight:700;margin-bottom:20px;color:var(--accent)}
.create-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.create-actions{margin-top:16px;display:flex;gap:10px}
.btn-run{background:var(--accent);color:#000;font-weight:700;font-size:12px;padding:9px 20px;border-radius:var(--r);text-transform:uppercase;letter-spacing:.06em;display:flex;align-items:center;gap:6px;cursor:pointer;border:none}
.btn-run:hover:not(:disabled){background:var(--accent2)}
.btn-cancel{background:transparent;border:1px solid var(--border2);color:var(--text2);font-size:12px;padding:9px 16px;border-radius:var(--r);text-transform:uppercase;letter-spacing:.06em;cursor:pointer}
.btn-cancel:hover{color:var(--text)}
.char-count{font-size:10px;color:var(--text3);text-align:right;margin-top:3px;display:block}

/* Filter */
.filter-bar{display:flex;align-items:center;gap:8px;margin-bottom:18px;flex-wrap:wrap}
.filter-label{font-size:11px;color:var(--text2);font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.filter-btn{background:transparent;border:1px solid var(--border);color:var(--text2);font-size:11px;padding:4px 12px;border-radius:100px;font-family:var(--font-mono);font-weight:600;text-transform:uppercase;letter-spacing:.05em;cursor:pointer}
.filter-btn:hover{border-color:var(--accent);color:var(--accent)}
.filter-btn.active{background:var(--accent-dim);border-color:var(--accent);color:var(--accent)}

/* Task grid */
.task-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:14px}
.task-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:18px;cursor:pointer;transition:all .15s;animation:fadeUp .25s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.task-card:hover{border-color:var(--border2);transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.5)}
.tc-head{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:10px}
.tc-title{font-family:var(--font-head);font-size:14px;font-weight:700;line-height:1.3;word-break:break-word}
.tc-op{font-size:10px;color:var(--accent);font-weight:600;text-transform:uppercase;letter-spacing:.08em;margin-top:3px}
.tc-preview{font-size:11px;color:var(--text2);background:var(--bg3);padding:7px 10px;border-radius:5px;border-left:2px solid var(--border2);font-family:var(--font-mono);line-height:1.5;margin-bottom:10px;word-break:break-all}
.tc-foot{display:flex;align-items:center;justify-content:space-between}
.tc-date{font-size:10px;color:var(--text3)}
.btn-del{background:transparent;border:1px solid var(--border);color:var(--text3);width:24px;height:24px;border-radius:4px;font-size:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0}
.btn-del:hover{border-color:var(--err);color:var(--err)}

/* Badges */
.badge{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:3px 8px;border-radius:100px;white-space:nowrap;flex-shrink:0}
.badge-pending{background:rgba(167,139,250,.12);color:var(--pending-c)}
.badge-running{background:rgba(56,189,248,.12);color:var(--running-c)}
.badge-success{background:rgba(0,229,192,.1);color:var(--success)}
.badge-failed{background:rgba(255,77,106,.1);color:var(--err)}
.bdot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.bdot-run{animation:pulse 1.1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* Empty */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 0;gap:12px;color:var(--text2)}
.empty-icon{font-size:40px;opacity:.25;font-family:var(--font-head)}
.empty-state p{font-size:14px;font-weight:600}
.empty-state span{font-size:12px;color:var(--text3)}
.spin{width:24px;height:24px;border:2px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* DETAIL */
.detail-wrap{max-width:900px}
.detail-back{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--text2);cursor:pointer;margin-bottom:20px;padding:6px 10px;border-radius:var(--r);border:1px solid var(--border);background:transparent}
.detail-back:hover{border-color:var(--border2);color:var(--text)}
.detail-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:20px;flex-wrap:wrap}
.detail-title{font-family:var(--font-head);font-size:24px;font-weight:800;letter-spacing:-.03em;margin-bottom:8px;word-break:break-word}
.detail-meta{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.meta-op{font-size:11px;color:var(--accent);background:var(--accent-dim);padding:3px 8px;border-radius:4px;font-weight:600;text-transform:uppercase;letter-spacing:.07em}
.meta-date{font-size:11px;color:var(--text3)}
.meta-dur{font-size:11px;color:var(--text2)}
.progress-wrap{height:2px;background:var(--border);border-radius:1px;overflow:hidden;margin-bottom:16px}
.progress-bar{height:100%;background:var(--accent);border-radius:1px;transition:width 0.4s ease}
.detail-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.detail-section{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:20px;min-width:0}
.ds-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);margin-bottom:14px}
.code-pre{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:12px;font-size:12px;line-height:1.6;white-space:pre-wrap;word-break:break-all;max-height:280px;overflow-y:auto;color:var(--text);font-family:var(--font-mono)}
.result-pre{color:var(--accent)}

/* Word count */
.wc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.wc-stat{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:12px;text-align:center}
.wc-n{font-family:var(--font-head);font-size:22px;font-weight:800;color:var(--accent)}
.wc-l{font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--text2);margin-top:3px}
.freq-title{font-size:10px;color:var(--text2);margin-bottom:8px;font-weight:700;text-transform:uppercase;letter-spacing:.08em}
.freq-item{display:grid;grid-template-columns:80px 1fr 28px;align-items:center;gap:8px;margin-bottom:5px}
.freq-word{font-size:11px;font-family:var(--font-mono);color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.freq-bar-bg{background:var(--bg3);border-radius:2px;height:5px;overflow:hidden;border:1px solid var(--border)}
.freq-bar{height:100%;background:var(--accent);border-radius:2px}
.freq-cnt{font-size:10px;color:var(--text2);text-align:right}
.result-wait{display:flex;align-items:center;gap:10px;color:var(--text2);padding:20px 0;font-size:12px}
.result-failed-box{display:flex;align-items:flex-start;gap:8px;color:var(--err);padding:12px;background:rgba(255,77,106,.07);border-radius:var(--r);font-size:12px;border:1px solid rgba(255,77,106,.2)}

/* Logs */
.log-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:20px}
.log-container{max-height:320px;overflow-y:auto;display:flex;flex-direction:column;gap:3px}
.log-entry{display:flex;align-items:flex-start;gap:8px;padding:5px 8px;border-radius:4px;font-size:11px;line-height:1.5;animation:fadeUp .15s ease}
.log-info{background:rgba(255,255,255,.02)}
.log-warn{background:rgba(245,166,35,.07)}
.log-error{background:rgba(255,77,106,.07)}
.log-icon{flex-shrink:0;margin-top:1px;font-size:10px}
.log-info .log-icon{color:var(--accent)}
.log-warn .log-icon{color:var(--warn)}
.log-error .log-icon{color:var(--err)}
.log-time{color:var(--text3);flex-shrink:0;font-size:10px;margin-top:1px;white-space:nowrap}
.log-msg{color:var(--text);word-break:break-all}
.no-logs{color:var(--text3);font-size:12px;padding:16px 0}

/* Toast */
.toast-container{position:fixed;bottom:24px;right:24px;display:flex;flex-direction:column;gap:8px;z-index:9999;pointer-events:none}
.toast{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:10px 16px;font-size:12px;color:var(--text);pointer-events:all;animation:toastIn .2s ease;display:flex;align-items:center;gap:8px;max-width:300px}
@keyframes toastIn{from{opacity:0;transform:translateX(10px)}to{opacity:1;transform:translateX(0)}}
.toast-success{border-color:rgba(0,229,192,.35);color:var(--success)}
.toast-error{border-color:rgba(255,77,106,.35);color:var(--err)}
.toast-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;background:currentColor}

::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

@media(max-width:680px){
  .stats-row{grid-template-columns:repeat(3,1fr)}
  .create-grid{grid-template-columns:1fr}
  .detail-cols{grid-template-columns:1fr}
  .task-grid{grid-template-columns:1fr}
  .app-body{padding:20px 14px}
}
</style>
</head>
<body>

<!-- ══════════ AUTH ══════════ -->
<div id="page-auth" class="page active">
  <div class="auth-wrap">
    <div class="auth-box">
      <div class="auth-logo">
        <div class="auth-logo-mark">
          <svg viewBox="0 0 18 18" fill="none" width="16" height="16">
            <path d="M9 1L16 5V13L9 17L2 13V5L9 1Z" stroke="#00e5c0" stroke-width="1.5"/>
            <path d="M9 5L13 7.5V12.5L9 15L5 12.5V7.5L9 5Z" fill="#00e5c0" opacity=".25"/>
            <circle cx="9" cy="9" r="2" fill="#00e5c0"/>
          </svg>
        </div>
        <span class="auth-logo-name">TaskForge</span>
      </div>
      <div class="auth-tabs">
        <button class="auth-tab active" onclick="switchAuthTab('login')">Sign In</button>
        <button class="auth-tab" onclick="switchAuthTab('register')">Register</button>
      </div>
      <!-- LOGIN -->
      <div id="form-login" class="auth-form-panel active">
        <div id="login-err" class="err-box" style="display:none"></div>
        <div class="field"><label>Email</label><input id="login-email" type="email" placeholder="you@example.com"></div>
        <div class="field"><label>Password</label><input id="login-pass" type="password" placeholder="••••••••"></div>
        <button class="btn-primary" onclick="doLogin()">Sign In →</button>
        <p class="demo-hint">Demo: admin@taskforge.io / password123</p>
      </div>
      <!-- REGISTER -->
      <div id="form-register" class="auth-form-panel">
        <div id="reg-err" class="err-box" style="display:none"></div>
        <div class="field"><label>Username</label><input id="reg-user" type="text" placeholder="your_handle"></div>
        <div class="field"><label>Email</label><input id="reg-email" type="email" placeholder="you@example.com"></div>
        <div class="field"><label>Password</label><input id="reg-pass" type="password" placeholder="min 8 characters"></div>
        <button class="btn-primary" onclick="doRegister()">Create Account →</button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════ APP ══════════ -->
<div id="page-app" class="page">
  <nav class="navbar">
    <div class="nav-logo">
      <div class="nav-logo-mark">
        <svg viewBox="0 0 18 18" fill="none" width="13" height="13">
          <path d="M9 1L16 5V13L9 17L2 13V5L9 1Z" stroke="#00e5c0" stroke-width="1.5"/>
          <circle cx="9" cy="9" r="2" fill="#00e5c0"/>
        </svg>
      </div>
      <span class="nav-logo-name">TaskForge</span>
    </div>
    <span class="nav-user"><span class="nav-dot"></span><span id="nav-username">user</span></span>
    <button class="btn-signout" onclick="doLogout()">Sign Out</button>
  </nav>
  <div class="app-body">

    <!-- DASHBOARD -->
    <div id="view-dashboard" class="view active">
      <div class="dash-header">
        <div>
          <h1 class="dash-title">Dashboard</h1>
          <p class="dash-sub">Create &amp; monitor AI processing tasks</p>
        </div>
        <button class="btn-new-task" onclick="toggleCreate()">
          <span id="new-icon">+</span><span id="new-txt">New Task</span>
        </button>
      </div>

      <div class="stats-row">
        <div class="stat"><div class="stat-n" id="st-total">0</div><div class="stat-l">Total</div></div>
        <div class="stat stat-pending"><div class="stat-n" id="st-pending">0</div><div class="stat-l">Pending</div></div>
        <div class="stat stat-running"><div class="stat-n" id="st-running">0</div><div class="stat-l">Running</div></div>
        <div class="stat stat-success"><div class="stat-n" id="st-success">0</div><div class="stat-l">Success</div></div>
        <div class="stat stat-failed"><div class="stat-n" id="st-failed">0</div><div class="stat-l">Failed</div></div>
      </div>

      <div id="create-panel" class="create-panel">
        <div class="create-title">▶ New Task</div>
        <div id="create-err" class="err-box" style="display:none"></div>
        <div class="create-grid">
          <div class="field"><label>Task Title</label><input id="f-title" type="text" placeholder="e.g. Process customer feedback" maxlength="100"></div>
          <div class="field">
            <label>Operation</label>
            <select id="f-op">
              <option value="uppercase">Uppercase — Convert to UPPERCASE</option>
              <option value="lowercase">Lowercase — Convert to lowercase</option>
              <option value="reverse">Reverse — Reverse the string</option>
              <option value="word_count">Word Count — Frequency analysis</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label>Input Text</label>
          <textarea id="f-text" rows="4" placeholder="Enter text to process..." maxlength="10000" oninput="document.getElementById('f-cc').textContent=this.value.length+' / 10,000'"></textarea>
          <span class="char-count" id="f-cc">0 / 10,000</span>
        </div>
        <div class="create-actions">
          <button class="btn-run" onclick="createTask()">▶ Run Task</button>
          <button class="btn-cancel" onclick="toggleCreate(true)">Cancel</button>
        </div>
      </div>

      <div class="filter-bar">
        <span class="filter-label">Filter:</span>
        <button class="filter-btn active" onclick="setFilter(this,'')">All</button>
        <button class="filter-btn" onclick="setFilter(this,'pending')">Pending</button>
        <button class="filter-btn" onclick="setFilter(this,'running')">Running</button>
        <button class="filter-btn" onclick="setFilter(this,'success')">Success</button>
        <button class="filter-btn" onclick="setFilter(this,'failed')">Failed</button>
      </div>

      <div id="task-list"></div>
    </div>

    <!-- DETAIL -->
    <div id="view-detail" class="view">
      <div class="detail-wrap">
        <button class="detail-back" onclick="showDash()">← Back to Dashboard</button>
        <div class="detail-head">
          <div style="min-width:0">
            <h2 class="detail-title" id="d-title"></h2>
            <div class="detail-meta">
              <span class="meta-op" id="d-op"></span>
              <span class="meta-date" id="d-date"></span>
              <span class="meta-dur" id="d-dur"></span>
            </div>
          </div>
          <div id="d-badge" style="flex-shrink:0;margin-top:4px"></div>
        </div>
        <div class="progress-wrap" id="d-pw" style="display:none"><div class="progress-bar" id="d-pb" style="width:0%"></div></div>
        <div class="detail-cols">
          <div class="detail-section"><div class="ds-title">Input</div><pre class="code-pre" id="d-input"></pre></div>
          <div class="detail-section"><div class="ds-title">Result</div><div id="d-result"></div></div>
        </div>
        <div class="log-box"><div class="ds-title">Execution Logs</div><div class="log-container" id="d-logs"></div></div>
      </div>
    </div>

  </div>
</div>
<div class="toast-container" id="toasts"></div>

<script>
// ─── DATA STORE ────────────────────────────────────────────────
const DB = {
  users: [{ id:'u1', username:'admin', email:'admin@taskforge.io', password:'password123' }],
  tasks: [],
  seq: 1,
};
let ME = null, activeFilter = '', detailId = null;
let dashPoll, detailPoll;
const OPS = { uppercase:'Uppercase', lowercase:'Lowercase', reverse:'Reverse', word_count:'Word Count' };

// ─── AUTH ──────────────────────────────────────────────────────
function switchAuthTab(tab) {
  document.querySelectorAll('.auth-tab').forEach((t,i) =>
    t.classList.toggle('active', tab==='login' ? i===0 : i===1));
  document.getElementById('form-login').classList.toggle('active', tab==='login');
  document.getElementById('form-register').classList.toggle('active', tab==='register');
}
function showErr(id,msg){ const e=document.getElementById(id); e.textContent=msg; e.style.display='block'; }
function hideErr(id){ document.getElementById(id).style.display='none'; }

function doLogin() {
  hideErr('login-err');
  const em = document.getElementById('login-email').value.trim();
  const pw = document.getElementById('login-pass').value;
  if(!em||!pw) return showErr('login-err','Email and password required');
  const u = DB.users.find(u=>u.email===em && u.password===pw);
  if(!u) return showErr('login-err','Invalid credentials');
  enterApp(u);
}
function doRegister() {
  hideErr('reg-err');
  const uname = document.getElementById('reg-user').value.trim();
  const em = document.getElementById('reg-email').value.trim();
  const pw = document.getElementById('reg-pass').value;
  if(!uname||!em||!pw) return showErr('reg-err','All fields required');
  if(pw.length<8) return showErr('reg-err','Password must be at least 8 characters');
  if(DB.users.find(u=>u.email===em)) return showErr('reg-err','Email already registered');
  if(DB.users.find(u=>u.username===uname)) return showErr('reg-err','Username taken');
  const u = {id:'u'+Date.now(), username:uname, email:em, password:pw};
  DB.users.push(u);
  enterApp(u);
}
function enterApp(u) {
  ME = u;
  try { sessionStorage.setItem('tf_u', JSON.stringify(u)); } catch(e){}
  document.getElementById('nav-username').textContent = u.username;
  document.getElementById('page-auth').classList.remove('active');
  document.getElementById('page-app').classList.add('active');
  renderDash();
  dashPoll = setInterval(()=>{ if(ME) renderDash(); }, 600);
  toast('Welcome, '+u.username+'!', 'success');
}
function doLogout() {
  ME = null;
  try { sessionStorage.clear(); } catch(e){}
  clearInterval(dashPoll); clearInterval(detailPoll);
  document.getElementById('page-app').classList.remove('active');
  document.getElementById('page-auth').classList.add('active');
  showDash();
}
// Restore session
(function(){
  try {
    const s = sessionStorage.getItem('tf_u');
    if(s) enterApp(JSON.parse(s));
  } catch(e){}
})();

// ─── WORKER SIMULATION ────────────────────────────────────────
function workerProcess(upper,lower,rev,wc,text) {
  if(upper) return text.toUpperCase();
  if(lower) return text.toLowerCase();
  if(rev)   return text.split('').reverse().join('');
  // word_count
  const words = text.trim().split(/\s+/).filter(Boolean);
  const freq = {};
  words.forEach(w => { const c=w.replace(/[^a-zA-Z0-9]/g,'').toLowerCase(); if(c) freq[c]=(freq[c]||0)+1; });
  const top = Object.fromEntries(Object.entries(freq).sort((a,b)=>b[1]-a[1]).slice(0,15));
  return { count: words.length, unique: Object.keys(freq).length, chars: text.length, freq: top };
}

function simulateWorker(id) {
  const t = DB.tasks.find(t=>t.id===id); if(!t) return;
  const delay1 = 500 + Math.random()*700;
  const delay2 = 1800 + Math.random()*2200;
  setTimeout(() => {
    if(!DB.tasks.find(t=>t.id===id)) return;
    t.status='running'; t.startedAt=Date.now();
    t.logs.push({level:'info',message:'Worker picked up task from Redis queue',ts:new Date().toISOString()});
    t.logs.push({level:'info',message:'Executing operation: '+t.operation,ts:new Date().toISOString()});
    t._ps=Date.now(); t._pt=delay2;
    renderDash(); if(detailId===id) renderDetail(id);
  }, delay1);
  setTimeout(() => {
    if(!DB.tasks.find(t=>t.id===id)) return;
    try {
      const op = t.operation;
      const result = workerProcess(op==='uppercase',op==='lowercase',op==='reverse',op==='word_count',t.inputText);
      t.status='success'; t.result=result; t.completedAt=Date.now();
      t.logs.push({level:'info',message:'Operation completed in '+(t.completedAt-t.startedAt)+'ms',ts:new Date().toISOString()});
      t.logs.push({level:'info',message:'Task finished successfully',ts:new Date().toISOString()});
      toast('"'+t.title+'" completed!','success');
    } catch(e) {
      t.status='failed'; t.errorMessage=e.message; t.completedAt=Date.now();
      t.logs.push({level:'error',message:'Task failed: '+e.message,ts:new Date().toISOString()});
      toast('"'+t.title+'" failed','error');
    }
    renderDash(); if(detailId===id) renderDetail(id);
  }, delay1+delay2);
}

// ─── TASK ACTIONS ─────────────────────────────────────────────
function createTask() {
  hideErr('create-err');
  const title = document.getElementById('f-title').value.trim();
  const text  = document.getElementById('f-text').value;
  const op    = document.getElementById('f-op').value;
  if(!title) return showErr('create-err','Title is required');
  if(!text)  return showErr('create-err','Input text is required');
  const task = {
    id:'t'+Date.now()+'_'+(DB.seq++),
    title, inputText:text, operation:op,
    status:'pending', result:null, errorMessage:null,
    logs:[{level:'info',message:'Task created — pushed to Redis queue',ts:new Date().toISOString()}],
    userId:ME.id, createdAt:new Date().toISOString(),
    startedAt:null, completedAt:null,
  };
  DB.tasks.unshift(task);
  document.getElementById('f-title').value='';
  document.getElementById('f-text').value='';
  document.getElementById('f-cc').textContent='0 / 10,000';
  toggleCreate(true);
  renderDash();
  simulateWorker(task.id);
  toast('Task queued → Redis','success');
}
function deleteTask(id, ev) {
  ev.stopPropagation();
  const i = DB.tasks.findIndex(t=>t.id===id);
  if(i>-1) DB.tasks.splice(i,1);
  renderDash();
}

// ─── PANEL / FILTER ───────────────────────────────────────────
function toggleCreate(forceClose) {
  const p=document.getElementById('create-panel');
  const open=p.classList.contains('open');
  if(forceClose||open){ p.classList.remove('open'); document.getElementById('new-icon').textContent='+'; document.getElementById('new-txt').textContent='New Task'; }
  else { p.classList.add('open'); document.getElementById('new-icon').textContent='✕'; document.getElementById('new-txt').textContent='Cancel'; document.getElementById('f-title').focus(); }
  hideErr('create-err');
}
function setFilter(btn,val) {
  activeFilter=val;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderTaskList();
}

// ─── BADGE ────────────────────────────────────────────────────
function mkBadge(s) {
  const dots={pending:'',running:'bdot-run',success:'',failed:''};
  return `<span class="badge badge-${s}"><span class="bdot ${dots[s]}"></span>${s}</span>`;
}

// ─── RENDER DASHBOARD ─────────────────────────────────────────
function renderDash() {
  if(!ME) return;
  const all = DB.tasks.filter(t=>t.userId===ME.id);
  document.getElementById('st-total').textContent   = all.length;
  document.getElementById('st-pending').textContent = all.filter(t=>t.status==='pending').length;
  document.getElementById('st-running').textContent = all.filter(t=>t.status==='running').length;
  document.getElementById('st-success').textContent = all.filter(t=>t.status==='success').length;
  document.getElementById('st-failed').textContent  = all.filter(t=>t.status==='failed').length;
  renderTaskList();
}
function renderTaskList() {
  if(!ME) return;
  const tasks = DB.tasks.filter(t=>t.userId===ME.id && (!activeFilter||t.status===activeFilter));
  const el = document.getElementById('task-list');
  if(!tasks.length) {
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">◈</div><p>No tasks found</p><span>${activeFilter?'No '+activeFilter+' tasks':'Create your first task above'}</span></div>`;
    return;
  }
  el.innerHTML=`<div class="task-grid">${tasks.map(t=>`
    <div class="task-card" onclick="openDetail('${t.id}')">
      <div class="tc-head"><div style="min-width:0"><div class="tc-title">${esc(t.title)}</div><div class="tc-op">${OPS[t.operation]||t.operation}</div></div>${mkBadge(t.status)}</div>
      <div class="tc-preview">${esc(t.inputText.slice(0,90))}${t.inputText.length>90?'…':''}</div>
      <div class="tc-foot"><span class="tc-date">${fmtDate(t.createdAt)}</span><button class="btn-del" onclick="deleteTask('${t.id}',event)" title="Delete">✕</button></div>
    </div>`).join('')}</div>`;
}

// ─── DETAIL ───────────────────────────────────────────────────
function openDetail(id) {
  detailId=id;
  document.getElementById('view-dashboard').classList.remove('active');
  document.getElementById('view-detail').classList.add('active');
  renderDetail(id);
  clearInterval(detailPoll);
  detailPoll=setInterval(()=>{
    const t=DB.tasks.find(t=>t.id===id);
    if(!t||t.status==='success'||t.status==='failed'){ clearInterval(detailPoll); }
    renderDetail(id);
  }, 300);
}
function showDash() {
  clearInterval(detailPoll); detailId=null;
  document.getElementById('view-detail').classList.remove('active');
  document.getElementById('view-dashboard').classList.add('active');
  renderDash();
}
function renderDetail(id) {
  const t=DB.tasks.find(t=>t.id===id); if(!t) return;
  document.getElementById('d-title').textContent = t.title;
  document.getElementById('d-op').textContent    = OPS[t.operation]||t.operation;
  document.getElementById('d-date').textContent  = fmtDate(t.createdAt);
  document.getElementById('d-badge').innerHTML   = mkBadge(t.status);
  document.getElementById('d-input').textContent = t.inputText;
  const dur = (t.startedAt&&t.completedAt) ? (t.completedAt-t.startedAt)+'ms' : null;
  document.getElementById('d-dur').textContent = dur ? 'Completed in '+dur : '';

  // progress
  const pw=document.getElementById('d-pw'), pb=document.getElementById('d-pb');
  if(t.status==='running'&&t._ps&&t._pt) {
    pw.style.display='block';
    pb.style.width=Math.min(95,Math.round(((Date.now()-t._ps)/t._pt)*100))+'%';
  } else if(t.status==='success') {
    pw.style.display='block'; pb.style.width='100%';
  } else { pw.style.display='none'; pb.style.width='0%'; }

  // result
  const rd=document.getElementById('d-result');
  if(t.status==='pending') {
    rd.innerHTML=`<div class="result-wait"><div class="spin"></div>Waiting in queue…</div>`;
  } else if(t.status==='running') {
    rd.innerHTML=`<div class="result-wait"><div class="spin"></div>Processing…</div>`;
  } else if(t.status==='failed') {
    rd.innerHTML=`<div class="result-failed-box">✕ &nbsp;${esc(t.errorMessage||'Task failed')}</div>`;
  } else if(t.operation==='word_count'&&typeof t.result==='object') {
    const r=t.result, maxF=Math.max(1,...Object.values(r.freq||{1:1}));
    const frows=Object.entries(r.freq||{}).map(([w,c])=>`
      <div class="freq-item">
        <span class="freq-word">${esc(w)}</span>
        <div class="freq-bar-bg"><div class="freq-bar" style="width:${Math.round((c/maxF)*100)}%"></div></div>
        <span class="freq-cnt">${c}</span>
      </div>`).join('');
    rd.innerHTML=`<div class="wc-grid">
      <div class="wc-stat"><div class="wc-n">${r.count}</div><div class="wc-l">Words</div></div>
      <div class="wc-stat"><div class="wc-n">${r.unique}</div><div class="wc-l">Unique</div></div>
      <div class="wc-stat"><div class="wc-n">${r.chars}</div><div class="wc-l">Chars</div></div>
    </div><div class="freq-title">Top words</div>${frows}`;
  } else {
    rd.innerHTML=`<pre class="code-pre result-pre">${esc(String(t.result))}</pre>`;
  }

  // logs
  const lc=document.getElementById('d-logs');
  const icons={info:'●',warn:'▲',error:'✕'};
  if(!t.logs||!t.logs.length) { lc.innerHTML='<div class="no-logs">No logs yet</div>'; return; }
  lc.innerHTML=t.logs.map(l=>`
    <div class="log-entry log-${l.level}">
      <span class="log-icon">${icons[l.level]||'●'}</span>
      <span class="log-time">${fmtTime(l.ts)}</span>
      <span class="log-msg">${esc(l.message)}</span>
    </div>`).join('');
  lc.scrollTop=lc.scrollHeight;
}

// ─── TOAST ────────────────────────────────────────────────────
function toast(msg,type='success') {
  const c=document.getElementById('toasts');
  const el=document.createElement('div');
  el.className=`toast toast-${type}`;
  el.innerHTML=`<span class="toast-dot"></span>${esc(msg)}`;
  c.appendChild(el);
  setTimeout(()=>{ el.style.opacity='0'; el.style.transform='translateX(10px)'; el.style.transition='all .2s'; setTimeout(()=>el.remove(),200); },3200);
}

// ─── UTILS ────────────────────────────────────────────────────
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtDate(iso){ return new Date(iso).toLocaleString(undefined,{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}); }
function fmtTime(iso){ return new Date(iso).toLocaleTimeString(undefined,{hour:'2-digit',minute:'2-digit',second:'2-digit'}); }

// enter key shortcuts
document.getElementById('login-pass').addEventListener('keydown',e=>{ if(e.key==='Enter') doLogin(); });
document.getElementById('reg-pass').addEventListener('keydown',e=>{ if(e.key==='Enter') doRegister(); });
</script>
</body>
</html>
